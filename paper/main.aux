\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Causal Analysis: Query is necessary; demos are collectively sufficient.} (a) Noise injection disruption: query position shows 50--100\% accuracy drop in layers 0--14; demo positions show near-0\% disruption. (b) Position roles: query is necessary but not sufficient; individual demos are neither; all demos together are sufficient. (c) Information flow: probe accuracy at demo positions stays at 100\%; query position rises from 12\% to 83\%, peaking at layer 12.}}{6}{figure.caption.18}\protected@file@percent }
\newlabel{fig:causal}{{2}{6}{\textbf {Causal Analysis: Query is necessary; demos are collectively sufficient.} (a) Noise injection disruption: query position shows 50--100\% accuracy drop in layers 0--14; demo positions show near-0\% disruption. (b) Position roles: query is necessary but not sufficient; individual demos are neither; all demos together are sufficient. (c) Information flow: probe accuracy at demo positions stays at 100\%; query position rises from 12\% to 83\%, peaking at layer 12}{figure.caption.18}{}}
