\@writefile{toc}{\contentsline {subsection}{\numberline {4.5}Causal Tracing: Necessity vs.\ Sufficiency}{3}{subsection.4.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Main Results: Single-position intervention fails; multi-position succeeds.} (a) Layer sweep: single-position intervention (gray) achieves 0\% transfer at all 28 layers; multi-position intervention (orange) peaks at 96\% at layer 8. (b) Condition comparison at layer 8: \texttt  {all\_demo} (96\%) and \texttt  {output\_only} (94\%) both succeed; \texttt  {input\_only} fails (0\%). (c) Task pair transfer matrix: a cluster of tasks (uppercase, repeat, length) shows high bidirectional transfer (50--100\%).}}{4}{figure.caption.8}\protected@file@percent }
\newlabel{fig:main_results}{{1}{4}{\textbf {Main Results: Single-position intervention fails; multi-position succeeds.} (a) Layer sweep: single-position intervention (gray) achieves 0\% transfer at all 28 layers; multi-position intervention (orange) peaks at 96\% at layer 8. (b) Condition comparison at layer 8: \texttt {all\_demo} (96\%) and \texttt {output\_only} (94\%) both succeed; \texttt {input\_only} fails (0\%). (c) Task pair transfer matrix: a cluster of tasks (uppercase, repeat, length) shows high bidirectional transfer (50--100\%)}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Causal Analysis: Query is necessary; demos are collectively sufficient.} (a) Noise injection disruption: query position shows 50--100\% accuracy drop in layers 0--14; demo positions show near-0\% disruption. (b) Position roles: query is necessary but not sufficient; individual demos are neither; all demos together are sufficient. (c) Information flow: probe accuracy at demo positions stays at 100\%; query position rises from 12\% to 83\%, peaking at layer 12.}}{4}{figure.caption.11}\protected@file@percent }
\newlabel{fig:causal}{{2}{4}{\textbf {Causal Analysis: Query is necessary; demos are collectively sufficient.} (a) Noise injection disruption: query position shows 50--100\% accuracy drop in layers 0--14; demo positions show near-0\% disruption. (b) Position roles: query is necessary but not sufficient; individual demos are neither; all demos together are sufficient. (c) Information flow: probe accuracy at demo positions stays at 100\%; query position rises from 12\% to 83\%, peaking at layer 12}{figure.caption.11}{}}
